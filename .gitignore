# Python cache/artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
.venv/
venv/

# Environment and editor files
.env
.env.*
.vscode/

# Keep dataset/processed folders, ignore all files inside
/data/datasets/*
!/data/datasets/.gitkeep
/data/processed/*
